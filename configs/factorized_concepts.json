  "batch_size": 32,
  "epochs": 100,
  "early_stopping_patience": 10,
  "reduce_lr_patience": 3,
  "monitor": "val_reconstruction_ssim_metric",
  "monitor_mode": "max",
  "evaluate_official_test": true,
  "save_probe_latents": true,
  "intervention_max_images": 256,
  "part_roi_radius": 6,
  "reconstruction_loss": {
    "pixel": "l1",
    "pixel_weight": 1.0,
    "ssim_weight": 0.2,
    "edge_weight": 0.1
  },
  "experiments": [
    {
      "name": "factorized_clean_m",
      "mode": "concept",
      "concept_weight": 1.0,
      "semantic_method": "ste",
      "residual_dropout": 0.0,
      "residual_noise_std": 0.0
    },
    {
      "name": "factorized_mild_corruption",
      "mode": "concept",
      "concept_weight": 1.0,
      "semantic_method": "ste",
      "residual_dropout": 0.1,
      "residual_noise_std": 0.05
    },
    {
      "name": "factorized_medium_corruption",
      "mode": "concept",
      "concept_weight": 1.0,
      "semantic_method": "ste",
      "residual_dropout": 0.2,
      "residual_noise_std": 0.1
    },
    {
      "name": "matched_continuous_control",
      "mode": "control",
      "control_noise_std": "auto",
      "residual_dropout": 0.1,
      "residual_noise_std": 0.05
    },
    {
      "name": "concept_only",
      "mode": "concept_only",
      "concept_weight": 1.0,
      "semantic_method": "ste"
    }
  ]
}
