{
  "cub_root": "/cephfs/users/qin/projects/datasets/CUB_200_2011",
  "selected_attributes_path": "outputs/attribute_preparation/selected_attributes_final.json",
  "output_path": "outputs/factorized_concepts",
  "img_size": [64, 64],
  "validation_fraction": 0.15,
  "split_seed": 42,
  "training_seeds": [42, 43, 44],
  "learning_rate": 0.001,
  "gradient_clipnorm": 1.0,
