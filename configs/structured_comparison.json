    {
      "name": "structured_vector_K1024",
      "model_name": "structured_vector_lite",
      "latent_dim": 1024,
      "latent_grid_size": 8
    },
    {
      "name": "spatial_K1024",
      "model_name": "spatial_lite",
      "latent_channels": 16,
      "latent_grid_size": 8
    }
  ]
